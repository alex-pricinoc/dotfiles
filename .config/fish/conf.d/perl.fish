status --is-interactive || exit

alias perl 'perl -wl'
abbr perl_io -- 'perl -n' # Input/Output Processing
abbr perl_iop -- 'perl -p' # I/O Procession, with printing
abbr perl_f -- 'perl -na' # Field Processing
abbr perl_fp -- 'perl -pa' # Field Processing, wiwth printing

## paragraph mode
alias Perl 'perl -00'
abbr Perl_io -- 'Perl -n' # Input/Output Processing
abbr Perl_iop -- 'Perl -p' # I/O Procession, with printing
abbr Perl_f -- 'Perl -na' # Field Processing
abbr Perl_fp -- 'Perl -pa' # Field Processing, wiwth printing
